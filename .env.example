# ─── Required for flash-loan execution ───────────────────────────────────────
# Without these three vars the monitor runs in observe-only mode (no txs sent).

# Ethereum JSON-RPC endpoint (Alchemy / Infura / your own node)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Hex private key of the wallet that owns ArbitrageExecutor.sol
# This wallet only needs ETH for gas — it holds no principal.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Address of the deployed ArbitrageExecutor contract
ARB_CONTRACT_ADDR=0xYOUR_CONTRACT_ADDRESS_HERE

# ─── Optional execution tuning ────────────────────────────────────────────────

# Flash-loan borrow size in USD (default: 50000)
FLASH_LOAN_USDT=50000

# Minimum net profit in USD before sending a tx (default: 15)
# Set this above your expected gas cost to avoid unprofitable txs.
MIN_PROFIT_USDT=15

# Set to "1" to run in simulation-only mode (never broadcasts, just logs)
DRY_RUN=0

# Maximum gas base fee in gwei — skip execution if fee exceeds this (default: 50)
MAX_FEE_GWEI=50

# Priority fee tip to miners in gwei (default: 2)
PRIORITY_FEE_GWEI=2

# Gas limit for the arbitrage tx (default: 600000)
GAS_LIMIT=600000

# ─── Optional: Flashbots relay for MEV protection ────────────────────────────
# Transactions sent to Flashbots are not visible in the public mempool,
# eliminating sandwich / front-run risk.
# Leave blank to use the normal RPC endpoint above.
FLASHBOTS_RPC_URL=https://relay.flashbots.net

# ─── Foundry / deploy ────────────────────────────────────────────────────────
FOUNDRY_ETH_RPC_URL=${ETH_RPC_URL}
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY_HERE
