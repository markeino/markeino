# Binance Exchange Configuration
EXCHANGE=binance

# Binance API Credentials (Get from: https://www.binance.com/en/my/settings/api-management)
# For PAPER TRADING mode, you can leave these empty
# For LIVE TRADING mode, you MUST provide valid API keys
API_KEY=your_binance_api_key_here
API_SECRET=your_binance_api_secret_here

# Bot Settings
TRADING_MODE=paper  # Use 'paper' for simulation, 'live' for real trading
INITIAL_BALANCE=10000
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENTAGE=0.02
TAKE_PROFIT_PERCENTAGE=0.05

# Important: Enable "Spot Trading" permissions when creating your API key
# Do NOT enable withdrawal permissions for security
